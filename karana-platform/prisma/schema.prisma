generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  company       String?
  avatarUrl     String?
  passwordHash  String?
  role          Role      @default(CLIENT)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  messages      Message[]
  notifications Notification[]
  reviews       Review[]
}

enum Role {
  CLIENT
  ADMIN
  TEAM_MEMBER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// SERVICES (public catalog)
// ─────────────────────────────────────────

model Service {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  category    ServiceCategory
  shortDesc   String
  longDesc    String          @db.Text
  icon        String?
  coverImage  String?
  features    Json?
  startingAt  Float?
  turnaround  String?
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime        @default(now())

  projects Project[]
}

enum ServiceCategory {
  ENGINEERING
  SOFTWARE
  CREATIVE
  MANUFACTURING
  STRATEGY
  LOGISTICS
  HARDWARE
}

// ─────────────────────────────────────────
// PROJECTS (core entity)
// ─────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  projectNumber String        @unique
  title         String
  description   String        @db.Text
  status        ProjectStatus @default(PENDING_REVIEW)
  priority      Priority      @default(MEDIUM)

  clientId  String
  client    User    @relation(fields: [clientId], references: [id])
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  budget         Float?
  timeline       String?
  specifications Json?

  quotedAmount   Float?
  quotedTimeline String?
  quotedAt       DateTime?
  quoteNotes     String?   @db.Text

  depositAmount Float?
  depositPaid   Boolean       @default(false)
  totalPaid     Float         @default(0)
  paymentStatus PaymentStatus @default(UNPAID)

  startedAt    DateTime?
  dueDate      DateTime?
  deliveredAt  DateTime?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  adminNotes String? @db.Text
  assignedTo String?

  files      ProjectFile[]
  messages   Message[]
  milestones Milestone[]
  payments   Payment[]
  updates    ProjectUpdate[]
  review     Review?
}

enum ProjectStatus {
  PENDING_REVIEW
  QUOTED
  AWAITING_PAYMENT
  IN_PROGRESS
  REVISION_REQUESTED
  DELIVERED
  AWAITING_FINAL_PAYMENT
  COMPLETED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  DEPOSIT_PAID
  PARTIALLY_PAID
  FULLY_PAID
  REFUNDED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─────────────────────────────────────────
// FILES
// ─────────────────────────────────────────

model ProjectFile {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id])
  uploadedBy    String
  name          String
  url           String
  size          Int
  mimeType      String
  category      FileCategory @default(ATTACHMENT)
  isDeliverable Boolean      @default(false)
  createdAt     DateTime     @default(now())
}

enum FileCategory {
  ATTACHMENT
  REFERENCE
  DELIVERABLE
  REVISION
}

// ─────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// MILESTONES
// ─────────────────────────────────────────

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int       @default(0)
}

// ─────────────────────────────────────────
// PROJECT UPDATES
// ─────────────────────────────────────────

model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  title     String
  content   String   @db.Text
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Payment {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id])
  stripePaymentId String      @unique
  amount          Float
  currency        String      @default("USD")
  status          String
  type            PaymentType
  createdAt       DateTime    @default(now())
}

enum PaymentType {
  DEPOSIT
  MILESTONE
  FINAL
  FULL
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  PROJECT_QUOTED
  PAYMENT_RECEIVED
  PROJECT_UPDATED
  MESSAGE_RECEIVED
  DELIVERABLE_READY
  PROJECT_COMPLETED
}

// ─────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?  @db.Text
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
}
